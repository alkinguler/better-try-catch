{
	"name": "@alkinguler/better-try-catch",
	"version": "1.0.1",
	"description": "A better try-catch wrapper for TypeScript and JavaScript.",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup index.ts --format cjs,esm --dts --clean",
		"prepublishOnly": "bun run build"
	},
	"type": "module",
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/bun": "latest",
		"tsup": "^8.5.1"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/alkinguler/better-try-catch"
	}
}
